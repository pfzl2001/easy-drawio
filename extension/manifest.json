{
  "manifest_version": 3,
  "name": "Easy Draw.io - Sidebar Diagram Editor",
  "version": "1.0.0",
  "description": "Draw.io diagram editor in your browser sidebar. Draw flowcharts, UML, and more while browsing.",
  "permissions": [
    "sidePanel",
    "storage",
    "activeTab"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open Draw.io Sidebar",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "host_permissions": [
    "<all_urls>"
  ]
}